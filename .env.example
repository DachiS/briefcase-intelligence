# Database
DATABASE_URL="postgresql://username:password@localhost:5432/spy_magazine"

# JWT Secret (generate a random 32+ character string)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Stripe Keys (get from https://dashboard.stripe.com)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price IDs (create these in Stripe dashboard)
STRIPE_MONTHLY_PRICE_ID="price_..."
STRIPE_ANNUAL_PRICE_ID="price_..."

# AWS S3 (for PDF and image storage)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET="spy-magazine-pdfs"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (nodemailer - use Gmail or SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="Spy Magazine <your@gmail.com>"
